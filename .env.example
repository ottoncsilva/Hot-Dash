# =========================================================================
# Hot Dash - Variáveis de ambiente
# Copie para .env.local (dev) ou configure no EasyPanel (produção).
# =========================================================================

# ---- Login (uso próprio) --------------------------------------------------
# Credenciais de acesso à plataforma. Defina com seus valores.
AUTH_EMAIL=voce@exemplo.com
AUTH_PASSWORD=troque-esta-senha

# Segredo para assinar a sessão de login (cookie). Gere com:
#   openssl rand -base64 32
SESSION_SECRET=

# ---- Criptografia das senhas das contas (AES-256) -------------------------
# Chave-mestra usada para cifrar as senhas guardadas. Gere com:
#   openssl rand -base64 32
# ⚠️ NUNCA troque depois de cadastrar senhas — elas ficariam ilegíveis.
APP_ENCRYPTION_KEY=

# ---- Armazenamento na VPS -------------------------------------------------
# Diretório do banco (SQLite) e da mídia. No EasyPanel, monte um VOLUME
# PERSISTENTE neste caminho, senão os dados somem a cada deploy.
MEDIA_STORAGE_DIR=/app/data

# ---- Uploads --------------------------------------------------------------
# Limite de upload do limpador de metadados / mídia (em MB).
NEXT_PUBLIC_MAX_UPLOAD_MB=200

# ---- Pagamentos (opcional) ------------------------------------------------
# As CHAVES da SyncPay são configuradas na tela de Configurações
# (guardadas criptografadas no banco), não aqui. Só ajuste a base da API da
# SyncPay se a sua conta usar outro endpoint.
# SYNCPAY_BASE_URL=https://api.syncpayments.com.br

# ---- Censura por IA (NudeNet) ---------------------------------------------
# Endereço do microserviço de detecção (ver pasta nudenet-service/).
# OPCIONAL: dá para configurar tudo pela interface, em
#   Configurações → Conexão com IA → NudeNet (URL + token),
# sem variável de ambiente e sem redeploy. Estas variáveis servem só como
# fallback (ex.: quando se usa o docker-compose.yml, que já as define).
# NUDENET_URL=http://nudenet:8000
# NUDENET_API_KEY=
