# =========================================================================
# Hot Dash - Variáveis de ambiente
# Copie para .env.local (dev) ou configure no EasyPanel (produção).
# Pegue estes valores em: Firebase Console > Configurações do projeto >
# Seus apps > App da Web (SDK setup and configuration).
# As variáveis NEXT_PUBLIC_* são seguras para o navegador.
# =========================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Limite de upload do limpador de metadados (em MB)
NEXT_PUBLIC_MAX_UPLOAD_MB=200
